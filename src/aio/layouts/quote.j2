{#- quote.j2 — Large blockquote with attribution. -#}
{% extends "base.j2" %}

{% block slide_content %}
<div class="layout-content quote-content">
  <blockquote class="layout-quote">
    <p class="quote-text">{% block quote_text %}{{ quote_text | default("") }}{% endblock %}</p>
    {% if quote_attribution or not quote_attribution is defined %}
    <footer>
      <p class="quote-author">&#8212; {% block quote_author %}{{ quote_attribution | default("") }}{% endblock %}</p>
    </footer>
    {% endif %}
  </blockquote>
</div>
{% endblock %}
