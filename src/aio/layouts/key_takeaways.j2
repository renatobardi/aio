{#- key_takeaways.j2 — Bulleted list with ✓ checkmarks via CSS ::before. -#}
{% extends "base.j2" %}

{% block slide_content %}
<div class="layout-content takeaways-content">
  <h2 class="takeaways-heading">{% block takeaways_title %}{{ title | default("Key Takeaways") }}{% endblock %}</h2>
  <div class="takeaways-list">
    {% block takeaways_body %}{{ body_html | default("") }}{% endblock %}
  </div>
</div>
{% endblock %}
