{#- stat_highlight.j2 — Giant stat number + label + description. -#}
{% extends "base.j2" %}

{% block slide_content %}
<div class="layout-content stat-content">
  <span class="stat">{% block stat_value %}{{ stat_value | default("—") }}{% endblock %}</span>
  <p class="stat-label">{% block stat_label %}{{ stat_label | default("") }}{% endblock %}</p>
  {% if stat_description or not stat_description is defined %}
  <p class="stat-description">{% block stat_description %}{{ stat_description | default("") }}{% endblock %}</p>
  {% endif %}
</div>
{% endblock %}
