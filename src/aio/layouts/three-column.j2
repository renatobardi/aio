<section class="slide slide--three-column">
  <h2 class="slide__title">{% block title %}{% endblock %}</h2>
  <div class="slide__columns">
    <div class="slide__col">{% block col1 %}{% endblock %}</div>
    <div class="slide__col">{% block col2 %}{% endblock %}</div>
    <div class="slide__col">{% block col3 %}{% endblock %}</div>
  </div>
</section>
