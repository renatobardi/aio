<section class="slide slide--comparison">
  <h2 class="slide__title">{% block title %}{% endblock %}</h2>
  <div class="slide__compare">
    <div class="slide__compare-a">{% block option_a %}{% endblock %}</div>
    <div class="slide__compare-vs">{% block versus %}vs{% endblock %}</div>
    <div class="slide__compare-b">{% block option_b %}{% endblock %}</div>
  </div>
</section>
