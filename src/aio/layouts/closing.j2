{#- closing.j2 — Thank you / call-to-action closing slide. -#}
{% extends "base.j2" %}

{% block slide_content %}
<div class="layout-content closing-content">
  <h1 class="closing-title">{% block closing_title %}{{ title | default("Thank You") }}{% endblock %}</h1>
  <div class="closing-body">{% block closing_body %}{{ body_html | default("") }}{% endblock %}</div>
  {% if cta_text %}
  <div class="cta-button">{% block cta %}{{ cta_text }}{% endblock %}</div>
  {% endif %}
</div>
{% endblock %}
