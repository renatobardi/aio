{#- hero_title.j2 — Full-viewport centered title + subtitle slide. -#}
{% extends "base.j2" %}

{% block slide_content %}
<div class="layout-content hero-content">
  <h1 class="hero-title">{% block hero_title %}{{ title | default("Untitled") }}{% endblock %}</h1>
  <p class="hero-subtitle">{% block hero_subtitle %}{{ body_html | striptags | default("") }}{% endblock %}</p>
</div>
{% endblock %}
