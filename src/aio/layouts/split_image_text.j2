{#- split_image_text.j2 — 50/50 CSS grid: image panel + text panel. -#}
{% extends "base.j2" %}

{% block slide_content %}
<div class="layout-content split-grid {% if image_position == 'right' %}split-image-right{% else %}split-image-left{% endif %}">
  <div class="split-image-panel">
    {% block split_image %}
    {% if image_src %}
    <img src="{{ image_src }}" alt="{{ image_alt | default('') }}" class="split-image" />
    {% else %}
    <div class="split-image-placeholder" aria-hidden="true"></div>
    {% endif %}
    {% endblock %}
  </div>
  <div class="split-text-panel">
    <h2 class="split-title">{% block split_title %}{{ title | default("") }}{% endblock %}</h2>
    <div class="split-body">{% block split_body %}{{ body_html | default("") }}{% endblock %}</div>
  </div>
</div>
{% endblock %}
