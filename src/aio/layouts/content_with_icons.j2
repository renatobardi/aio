{#- content_with_icons.j2 — 3-column icon + title + description grid. -#}
{% extends "base.j2" %}

{% block slide_content %}
<div class="layout-content icons-content">
  <h2 class="icons-heading">{% block icons_title %}{{ title | default("") }}{% endblock %}</h2>
  <div class="icons-grid">
    {% block icons_body %}{{ body_html | default("") }}{% endblock %}
  </div>
</div>
{% endblock %}
