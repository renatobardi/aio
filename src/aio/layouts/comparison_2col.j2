{#- comparison_2col.j2 — Side-by-side two-column comparison. -#}
{% extends "base.j2" %}

{% block slide_content %}
<div class="layout-content comparison-grid">
  <div class="comparison-col comparison-left">
    <h3 class="comparison-col-title">{% block left_title %}{{ left_title | default("Option A") }}{% endblock %}</h3>
    <div class="comparison-col-body">{% block left_content %}{{ left_content | default("") }}{% endblock %}</div>
  </div>
  <div class="comparison-col comparison-right">
    <h3 class="comparison-col-title">{% block right_title %}{{ right_title | default("Option B") }}{% endblock %}</h3>
    <div class="comparison-col-body">{% block right_content %}{{ right_content | default("") }}{% endblock %}</div>
  </div>
</div>
{% endblock %}
